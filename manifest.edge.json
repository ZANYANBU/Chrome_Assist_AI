{
    "manifest_version":  3,
    "name":  "ZANYSURF Browser Agent",
    "short_name":  "ZANYSURF",
    "author":  "Anbuchelvan Valavan",
    "version":  "2.0.0",
    "description":  "AI browser agent with local Ollama, Edge built-in AI, or cloud providers for guided autonomous web navigation and task automation.",
    "browser_specific_settings":  {
                                      "edge":  {
                                                   "browser_action_next_to_address_bar":  true
                                               }
                                  },
    "icons":  {
                  "16":  "icons/icon16.png",
                  "48":  "icons/icon48.png",
                  "128":  "icons/icon128.png"
              },
    "permissions":  [
                        "activeTab",
                        "scripting",
                        "storage",
                        "declarativeNetRequest",
                        "alarms",
                        "tabs",
                        "downloads",
                        "clipboardWrite",
                        "contextMenus",
                        "notifications",
                        "sidePanel"
                    ],
    "side_panel":  {
                       "default_path":  "popup.html"
                   },
    "action":  {
                   "default_popup":  "popup.html",
                   "default_title":  "ZANYSURF AI Agent",
                   "default_icon":  {
                                        "16":  "icons/icon16.png",
                                        "48":  "icons/icon48.png",
                                        "128":  "icons/icon128.png"
                                    }
               },
    "background":  {
                       "service_worker":  "background.js"
                   },
    "content_scripts":  [
                            {
                                "matches":  [
                                                "\u003call_urls\u003e"
                                            ],
                                "js":  [
                                           "content.js"
                                       ],
                                "run_at":  "document_idle",
                                "all_frames":  false
                            }
                        ],
    "host_permissions":  [
                             "\u003call_urls\u003e",
                             "https://generativelanguage.googleapis.com/*",
                             "http://localhost:11434/*",
                             "http://127.0.0.1:11434/*",
                             "https://api.openai.com/*",
                             "https://api.anthropic.com/*",
                             "https://api.groq.com/*",
                             "https://api.mistral.ai/*"
                         ],
    "web_accessible_resources":  [
                                     {
                                         "resources":  [
                                                           "content.js",
                                                           "dom-text-worker.js",
                                                           "selftest.html"
                                                       ],
                                         "matches":  [
                                                         "\u003call_urls\u003e"
                                                     ]
                                     }
                                 ],
    "content_security_policy":  {
                                    "extension_pages":  "script-src \u0027self\u0027; object-src \u0027self\u0027"
                                },
    "commands":  {
                     "toggle-sidepanel":  {
                                              "suggested_key":  {
                                                                    "default":  "Alt+Z"
                                                                },
                                              "description":  "Toggle ZANYSURF side panel"
                                          }
                 },
    "externally_connectable":  {
                                   "matches":  [
                                                   "*://localhost/*",
                                                   "*://127.0.0.1/*",
                                                   "https://*.zanysurf.com/*"
                                               ]
                               }
}

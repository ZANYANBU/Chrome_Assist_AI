{
  "manifest_version": 3,
  "name": "ZANYSURF Browser Agent",
  "short_name": "ZANYSURF",
  "author": "Anbuchelvan Valavan",
  "version": "2.0.0",
  "description": "AI browser agent with local Ollama or Gemini for guided autonomous web navigation and task automation.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "declarativeNetRequest",
    "alarms",
    "tabs",
    "downloads",
    "clipboardWrite",
    "contextMenus",
    "notifications",
    "sidePanel"
  ],
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ZANYSURF AI Agent",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "host_permissions": [
    "<all_urls>",
    "https://generativelanguage.googleapis.com/*",
    "http://localhost:11434/*",
    "http://127.0.0.1:11434/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://api.groq.com/*",
    "https://api.mistral.ai/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.js", "dom-text-worker.js", "selftest.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "commands": {
    "toggle-sidepanel": {
      "suggested_key": {
        "default": "Alt+Z"
      },
      "description": "Toggle ZANYSURF side panel"
    }
  }
}

